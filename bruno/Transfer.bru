meta {
  name: Transfer
  type: http
  seq: 3
}

post {
  url: http://localhost:8080/v1/transfers
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "sourceAccountId": "{{accountIdA}}",
    "destinationAccountId": "{{accountIdB}}",
    "amount": 50.00
  }
}

vars:pre-request {
  accountIdB: 8f9306a6-ac2c-46ce-b820-725012db9fb7
  accountIdA: 02489d7b-d3c4-4777-a2d3-01b08be04385
